# ─── Focus Reminder — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Gmail address you're sending FROM
SENDER_EMAIL=your_gmail@gmail.com

# Gmail address that receives the notification (can be the same as above)
RECEIVER_EMAIL=your_gmail@gmail.com

# Gmail App Password (NOT your regular password)
# How to get one: Google Account → Security → 2-Step Verification → App passwords
APP_PASSWORD=xxxx xxxx xxxx xxxx

# How often to send reminders (in minutes)
SEND_INTERVAL_MINUTES=45

# Only send between these hours (24h format)
ACTIVE_HOURS_START=10
ACTIVE_HOURS_END=23
